{
  "entities": {
    "Category": {
      "title": "Category",
      "type": "object",
      "description": "Represents a classification for properties (e.g., Residential, Commercial).",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Property": {
      "title": "Property",
      "type": "object",
      "description": "Details for finished or under-construction properties.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "code": { "type": "string" },
        "categoryId": { "type": "string" },
        "location": { "type": "string" },
        "size": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["Finished", "Under Construction"] },
        "status": { "type": "string", "enum": ["Occupied", "Vacant"] },
        "monthlyRent": { "type": "number" },
        "paymentDueDay": { "type": "number", "description": "Day of the month rent is due (1-31)" },
        "totalInvestment": { "type": "number" },
        "constructionStage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "members": { "type": "object", "description": "Map of user IDs to roles for access control" },
        "tenantName": { "type": "string" },
        "tenantContact": { "type": "string" }
      },
      "required": ["name", "code", "location", "type", "createdAt", "members"]
    },
    "ConstructionExpense": {
      "title": "ConstructionExpense",
      "type": "object",
      "properties": {
        "propertyId": { "type": "string" },
        "itemName": { "type": "string" },
        "quantity": { "type": "number" },
        "unitPrice": { "type": "number" },
        "totalPrice": { "type": "number" },
        "vendor": { "type": "string" },
        "purchaseDate": { "type": "string", "format": "date-time" }
      }
    },
    "RentalIncome": {
      "title": "RentalIncome",
      "type": "object",
      "properties": {
        "propertyId": { "type": "string" },
        "tenantName": { "type": "string" },
        "amount": { "type": "number" },
        "paymentDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Paid", "Pending", "Overdue"] },
        "monthKey": { "type": "string", "description": "Identifier for the month (YYYY-MM)" },
        "paymentMethod": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/finished_properties/{propertyId}": {
      "schema": { "$ref": "#/backend/entities/Property" },
      "description": "Collection for all properties."
    },
    "/construction_expenses/{expenseId}": {
      "schema": { "$ref": "#/backend/entities/ConstructionExpense" },
      "description": "Expenses incurred during construction."
    },
    "/rental_incomes/{incomeId}": {
      "schema": { "$ref": "#/backend/entities/RentalIncome" },
      "description": "Rental income records."
    },
    "/maintenance_expenses/{expenseId}": {
      "schema": { "type": "object" },
      "description": "Maintenance records."
    },
    "/construction_budget_items/{itemId}": {
      "schema": { "type": "object" },
      "description": "Budget line items for construction."
    },
    "/maintenance_budget_items/{itemId}": {
      "schema": { "type": "object" },
      "description": "Budget line items for maintenance."
    }
  }
}
