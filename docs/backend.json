
{
  "entities": {
    "Category": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Category",
      "type": "object",
      "description": "Represents a classification for properties, helping to organize and filter them (e.g., Residential, Commercial).",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Category entity."
        },
        "name": {
          "type": "string",
          "description": "The name of the property category (e.g., 'Residential', 'Commercial', 'Land')."
        },
        "description": {
          "type": "string",
          "description": "A brief explanation or context for this property category."
        }
      },
      "required": [
        "id",
        "name",
        "description"
      ]
    },
    "Property": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Property",
      "type": "object",
      "description": "Manages details for both finished and under-construction properties.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Property entity."
        },
        "name": {
          "type": "string",
          "description": "The common name given to the property."
        },
        "code": {
          "type": "string",
          "description": "A unique identifier code for the property."
        },
        "categoryId": {
          "type": "string",
          "description": "Reference to Category."
        },
        "location": {
          "type": "string",
          "description": "The physical location or address of the property."
        },
        "size": {
          "type": "string",
          "description": "The total size of the property."
        },
        "description": {
          "type": "string",
          "description": "A detailed description."
        },
        "type": {
          "type": "string",
          "description": "Indicates the stage (e.g., 'Finished', 'Under Construction')."
        },
        "createdAt": {
          "type": "string",
          "description": "Creation date-time.",
          "format": "date-time"
        },
        "isDeleted": {
          "type": "boolean",
          "description": "Soft-delete flag."
        },
        "status": {
          "type": "string",
          "description": "Occupancy status (e.g., 'Occupied', 'Vacant')."
        },
        "monthlyRent": {
          "type": "number",
          "description": "Expected monthly rent."
        },
        "paymentDueDay": {
          "type": "number",
          "description": "Rent due day."
        },
        "tenantName": {
          "type": "string",
          "description": "Current tenant name."
        },
        "tenantContact": {
          "type": "string",
          "description": "Tenant contact info."
        },
        "totalInvestment": {
          "type": "number",
          "description": "Total investment cost."
        },
        "members": {
          "type": "object",
          "description": "A map of user IDs to roles (admin, manager, viewer) for authorization."
        }
      },
      "required": [
        "name",
        "code",
        "location",
        "type",
        "createdAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/finished_properties/{propertyId}",
        "definition": {
          "entityName": "Property",
          "schema": {
            "$ref": "#/backend/entities/Property"
          },
          "description": "Collection for all finished properties.",
          "params": [
            {
              "name": "propertyId",
              "description": "The unique ID of the property."
            }
          ]
        }
      }
    ]
  }
}
