
{
  "entities": {
    "Category": {
      "title": "Category",
      "type": "object",
      "description": "Represents a classification for properties (e.g., Stand Alone, Apartment, Flat).",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "PropertyUnit": {
      "title": "PropertyUnit",
      "type": "object",
      "description": "Details for a specific unit within a multi-unit property.",
      "properties": {
        "id": { "type": "string" },
        "unitName": { "type": "string" },
        "status": { "type": "string", "enum": ["Occupied", "Vacant"] },
        "monthlyRent": { "type": "number" },
        "paymentDueDay": { "type": "number" },
        "tenantName": { "type": "string" },
        "tenantContact": { "type": "string" }
      }
    },
    "Property": {
      "title": "Property",
      "type": "object",
      "description": "Details for finished or under-construction properties.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "code": { "type": "string" },
        "categoryId": { "type": "string" },
        "location": { "type": "string" },
        "size": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["Finished", "Under Construction"] },
        "status": { "type": "string", "enum": ["Occupied", "Vacant"] },
        "monthlyRent": { "type": "number" },
        "paymentDueDay": { "type": "number" },
        "totalInvestment": { "type": "number" },
        "units": { "type": "number", "description": "Number of units for multi-unit properties" },
        "unitsList": {
          "type": "array",
          "items": { "$ref": "#/backend/entities/PropertyUnit" }
        },
        "constructionStage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "members": { "type": "object" },
        "tenantName": { "type": "string" },
        "tenantContact": { "type": "string" }
      },
      "required": ["name", "code", "location", "type", "createdAt", "members", "categoryId"]
    },
    "ConstructionExpense": {
      "title": "ConstructionExpense",
      "type": "object",
      "properties": {
        "propertyId": { "type": "string" },
        "itemName": { "type": "string" },
        "quantity": { "type": "number" },
        "unitPrice": { "type": "number" },
        "totalPrice": { "type": "number" },
        "vendor": { "type": "string" },
        "purchaseDate": { "type": "string", "format": "date-time" }
      }
    },
    "MaintenanceExpense": {
      "title": "MaintenanceExpense",
      "type": "object",
      "properties": {
        "propertyId": { "type": "string" },
        "expenseType": { "type": "string", "enum": ["Repair", "Utility", "Cleaning", "Other"] },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "vendor": { "type": "string" },
        "unitIds": { "type": "array", "items": { "type": "string" } },
        "unitNames": { "type": "array", "items": { "type": "string" } }
      }
    },
    "RentalIncome": {
      "title": "RentalIncome",
      "type": "object",
      "properties": {
        "propertyId": { "type": "string" },
        "unitId": { "type": "string" },
        "unitName": { "type": "string" },
        "tenantName": { "type": "string" },
        "amount": { "type": "number" },
        "paymentDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Paid", "Pending", "Overdue"] },
        "monthKey": { "type": "string" },
        "paymentMethod": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/finished_properties/{propertyId}": {
      "schema": { "$ref": "#/backend/entities/Property" },
      "description": "Collection for all properties."
    },
    "/construction_expenses/{expenseId}": {
      "schema": { "$ref": "#/backend/entities/ConstructionExpense" },
      "description": "Expenses incurred during construction."
    },
    "/maintenance_expenses/{expenseId}": {
      "schema": { "$ref": "#/backend/entities/MaintenanceExpense" },
      "description": "Expenses incurred for ongoing maintenance."
    },
    "/rental_incomes/{incomeId}": {
      "schema": { "$ref": "#/backend/entities/RentalIncome" },
      "description": "Rental income records."
    }
  }
}
