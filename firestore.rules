
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasGlobalAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isMember(data) {
      return isSignedIn() && (data.members[request.auth.uid] != null || hasGlobalAdmin());
    }

    function isAdmin(data) {
      return isSignedIn() && (data.members[request.auth.uid] == 'admin' || hasGlobalAdmin());
    }

    // --- Collection Rules ---

    match /finished_properties/{propertyId} {
      allow get, list: if isMember(resource.data);
      allow create: if isSignedIn() && request.resource.data.members[request.auth.uid] == 'admin';
      allow update, delete: if isAdmin(resource.data);
    }

    match /properties/{propertyId} {
      allow get, list: if isMember(resource.data);
      allow create: if isSignedIn() && request.resource.data.members[request.auth.uid] == 'admin';
      allow update: if isAdmin(resource.data);
      allow delete: if isAdmin(resource.data);
    }
    
    match /roles_admin/{userId} {
      allow get: if isOwner(userId);
      allow create, update, delete: if hasGlobalAdmin();
    }
  }
}
