
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // --- Collection Rules ---

    // Allowing all authenticated users read/write access for initial setup phase.
    // In a production app, these should be restricted to specific members/roles.

    match /finished_properties/{propertyId} {
      allow read, write: if isSignedIn();
    }

    match /properties/{propertyId} {
      allow read, write: if isSignedIn();
    }
    
    match /roles_admin/{userId} {
      allow read, write: if isSignedIn();
    }
  }
}
