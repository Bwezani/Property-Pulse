rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(data) {
      return isSignedIn() && (data.userId == request.auth.uid || (data.members != null && request.auth.uid in data.members));
    }

    function isNewOwner() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // Secure all collections
    match /finished_properties/{propertyId} {
      allow read, update, delete: if isOwner(resource.data);
      allow create: if isNewOwner();
    }
    
    match /construction_properties/{propertyId} {
      allow read, update, delete: if isOwner(resource.data);
      allow create: if isNewOwner();
    }
    
    match /construction_expenses/{expenseId} {
      allow read, update, delete: if isOwner(resource.data);
      allow create: if isNewOwner();
    }
    
    match /maintenance_expenses/{expenseId} {
      allow read, update, delete: if isOwner(resource.data);
      allow create: if isNewOwner();
    }
    
    match /rental_incomes/{incomeId} {
      allow read, update, delete: if isOwner(resource.data);
      allow create: if isNewOwner();
    }

    match /construction_budget_items/{itemId} {
      allow read, update, delete: if isOwner(resource.data);
      allow create: if isNewOwner();
    }

    match /maintenance_budget_items/{itemId} {
      allow read, update, delete: if isOwner(resource.data);
      allow create: if isNewOwner();
    }
  }
}