
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Development-friendly rules: allow all authenticated users
    // We explicitly match the collection and its documents to ensure all operations (get, list, write) are permitted.
    
    match /finished_properties/{propertyId} {
      allow read, write: if request.auth != null;
    }
    
    match /finished_properties {
      allow list: if request.auth != null;
    }

    // General fallback for all other collections
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
